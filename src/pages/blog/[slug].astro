---
import { CollectionEntry, getCollection, render } from "astro:content";

import { H1, Link, MDXComponents } from "@/components";
import { constants } from "@/config";
import Page from "@/layouts/page.astro";

export const getStaticPaths = async () => {
  const posts = await getCollection("posts");
  return posts.map((post: any) => ({
    params: { slug: post.id },
    props: post,
  }));
};

const posts = (await getCollection("posts")).sort(
  (a: any, z: any) => +new Date(z.data.date) - +new Date(a.data.date)
);
const post = Astro.props as CollectionEntry<"posts">;
const tags = [...new Set(post.data.tags)].sort();
const { Content } = await render(post);

const index = posts.findIndex(({ id }) => id === post.id);
const prev = posts?.[index + 1];
const next = posts?.[index - 1];
---

<Page
  title={`${post.data.title} | Gangeshwar Krishnamurthy`}
  description={post.data.description}
  keywords={`blog, post, ${tags.join(", ")}`}
  image={`/images/${post.id}.png`}
  type="article"
  date={post.data.date}
>
  <H1>{post.data.title}</H1>
  <p class="">{post.data.description}</p>

  <div class="mt-5 text-sm">
    <span class="opacity-70">{post.data.date}</span>
    <Link href="https://gangeshwark.com"> - Gangeshwar Krishnamurthy</Link>
  </div>

  <hr class="h-16 border-0" />

  <Content components={MDXComponents} />

  <hr class="h-4 border-0" />

  <section class="my-8 text-sm">
    <div class="my-8 flex justify-center gap-4 sm:justify-end sm:gap-6">
      <Link
        href={`https://x.com/intent/tweet` +
          `?text=${post.data.title} — ${post.data.description}` +
          `&url=${constants.site}/blog/${post.id}` +
          `&via=gangeshwark` +
          `&hashtags=${tags.join(",")}`}
      >
        Share on X
      </Link>

      <Link
        href={`https://x.com/search?q=${constants.site}/blog/${post.id}&src=typed_query`}
      >
        Discuss on X
      </Link>
    </div>

    <div class="my-4 flex gap-8 text-sm">
      {
        prev ? (
          <Link
            class="mr-auto flex w-1/2 truncate rounded-sm py-2 text-left font-medium"
            href={`/blog/${prev.id}`}
          >
            <span class="mr-2">←</span>
            <span class="flex-1 truncate">{prev.data.title}</span>
          </Link>
        ) : null
      }

      {
        next ? (
          <Link
            class="ml-auto flex w-1/2 truncate rounded-sm py-2 text-right font-medium"
            href={`/blog/${next.id}`}
          >
            <span class="flex-1 truncate">{next.data.title}</span>
            <span class="ml-2">→</span>
          </Link>
        ) : null
      }
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll(".copy-code").forEach((button) => {
      button.addEventListener("click", (event) => {
        navigator.clipboard
          .writeText(String(event.target.nextSibling?.textContent))
          .then(() => (event.target.textContent = "Copied!"))
          .catch(() => (event.target.textContent = "Not supported"));
      });
      button.addEventListener(
        "blur",
        (event) => (event.target.textContent = "Copy")
      );
    });
  </script>
</Page>
