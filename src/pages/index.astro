---
import { Link, List, ListItem } from "@/components";
import { constants } from "@/config";
import iconMail from "@tabler/icons/outline/mail.svg?raw";
import iconGithub from "@tabler/icons/outline/brand-github.svg?raw";
import iconX from "@tabler/icons/outline/brand-x.svg?raw";
import Page from "@/layouts/page.astro";
---

<Page
  title={constants.profile.title}
  description={constants.profile.description}
  keywords="personal, website, blog"
  image={constants.profile.image}
  type="website"
>
  <h1 class="mb-10 text-4xl font-bold">I build products that scale.</h1>
  <section>
    <div>
      <img
        class="rounded-full"
        src="/profile.jpg"
        alt="Gangeshwar"
        width={150}
        height={150}
      />
    </div>
  </section>
  <section class="mt-14 space-y-2">
    <h2 class="text-xl font-normal leading-loose sm:leading-loose">
      I’m Gangeshwar Krishnamurthy, Co-founder & CTO of <a
        class="underline"
        href="https://mindfi.co/"
        target="_blank">MindFi (YC S21)</a
      > in Singapore. I lead engineering across product, platform, and AI systems
      with a focus on reliability, speed, and user impact.
    </h2>

    <h2 class="text-xl font-normal leading-loose sm:leading-loose">
      Over the last decade, I’ve worked across research and startups, turning
      complex ideas into production systems used by real people.
    </h2>
  </section>

  <section class="mt-12 flex items-center gap-4">
    <Link href={constants.profile.links.email} classList={{ ["text-default"]: true }} aria-label="Email">
      <span class="inline-flex [&>svg]:h-5 [&>svg]:w-5" set:html={iconMail} />
    </Link>

    <Link href={constants.profile.links.github} classList={{ ["text-default"]: true }} aria-label="GitHub">
      <span class="inline-flex [&>svg]:h-5 [&>svg]:w-5" set:html={iconGithub} />
    </Link>

    <Link href={constants.profile.links.twitter} classList={{ ["text-default"]: true }} aria-label="X">
      <span class="inline-flex [&>svg]:h-5 [&>svg]:w-5" set:html={iconX} />
    </Link>
  </section>

  <section class="mb-16">
    <h2 class="mt-28 text-2xl font-bold">Selected Research</h2>

    <List class="mt-12 list-none space-y-4">
      {
        constants.publications
          .slice(0, 3)
          .map(({ name, description, link }) => (
            <ListItem>
              <Link href={link}>{name}</Link> — {description}
            </ListItem>
          ))
      }
    </List>

    <Link href="/publications" class="mt-10 inline-block text-sm font-medium">
      Browse all publications <span class="ml-2">→</span>
    </Link>
  </section>
</Page>
